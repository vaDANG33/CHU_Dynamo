    {
      "ConcreteType": "Dynamo.Nodes.DSModelElementSelection, DSRevitNodesUI",
      "NodeType": "ExtensionNode",
      "InstanceId": [
        "1ca1f79c-8142-4213-aaba-157280350dc6-0016ee25"
      ],
      "Id": "fbe076c1ae384b9a917de0ebe71d4603",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "68d0fa2fa59e457aad99315af15f4dcc",
          "Name": "Element",
          "Description": "Eléments sélectionnés.",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# -*- coding: utf-8 -*-\r\nimport clr\r\n\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitNodes')\r\nclr.AddReference('RevitServices')\r\n\r\nfrom Autodesk.Revit.DB import *\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nimport Revit\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# =============================================================================\r\n# INPUTS\r\n# IN[0] : Liste de points Dynamo (origines des rayons)\r\n# IN[1] : Direction du rayon  ex. Vector.ByCoordinates(0, 0, -1)\r\n# IN[2] : Vue 3D              (obligatoire pour ReferenceIntersector)\r\n# IN[3] : Catégorie Dynamo    ex. Categories → \"Plafonds\"\r\n# IN[4] : RevitLinkInstance   (fichier lié contenant les plafonds)\r\n# IN[5] : FamilySymbol        (la dalle luminaire face-hosted)\r\n# IN[6] : Level               (niveau de nomenclature)\r\n# =============================================================================\r\n\r\npoints          = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\ndirection       = IN[1]\r\nview3D          = UnwrapElement(IN[2])\r\ncategory        = IN[3]\r\nlinked_instance = UnwrapElement(IN[4])\r\nfamily_symbol   = UnwrapElement(IN[5])\r\nref_level       = UnwrapElement(IN[6])\r\n\r\n# --- Conversion direction Dynamo → XYZ Revit ---\r\ndir_xyz = direction.ToRevitType()\r\n\r\n# --- Document et transformation du lien ---\r\nlink_doc       = linked_instance.GetLinkDocument()\r\nlink_transform = linked_instance.GetTotalTransform()\r\n\r\n# =============================================================================\r\n# FONCTION UTILITAIRE : projection d'un vecteur dans le plan de la face\r\n# Utilisée pour calculer ref_direction sans décalage de 90°\r\n# =============================================================================\r\ndef project_on_plane(vector, normal):\r\n    \"\"\"\r\n    Projette 'vector' dans le plan défini par 'normal'.\r\n    Si BasisX est parallèle à la normale (plafond incliné), bascule sur BasisY.\r\n    \"\"\"\r\n    dot = vector.DotProduct(normal)\r\n    projected = XYZ(\r\n        vector.X - dot * normal.X,\r\n        vector.Y - dot * normal.Y,\r\n        vector.Z - dot * normal.Z\r\n    )\r\n    if projected.GetLength() < 1e-9:\r\n        dot2 = XYZ.BasisY.DotProduct(normal)\r\n        projected = XYZ(\r\n            XYZ.BasisY.X - dot2 * normal.X,\r\n            XYZ.BasisY.Y - dot2 * normal.Y,\r\n            XYZ.BasisY.Z - dot2 * normal.Z\r\n        )\r\n    return projected.Normalize()\r\n\r\n# =============================================================================\r\n# REFERENCE INTERSECTOR\r\n# =============================================================================\r\ntry:\r\n    cat_id = ElementId(int(category.Id))\r\nexcept:\r\n    cat_id = category.Id\r\n\r\ncat_filter = ElementCategoryFilter(cat_id)\r\nri = ReferenceIntersector(cat_filter, FindReferenceTarget.Face, view3D)\r\nri.FindReferencesInRevitLinks = True\r\n\r\n# =============================================================================\r\n# TRANSACTION\r\n# =============================================================================\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\nif not family_symbol.IsActive:\r\n    family_symbol.Activate()\r\n    doc.Regenerate()\r\n\r\nplaced_instances = []\r\nerrors           = []\r\nno_hit_points    = []\r\n\r\n# =============================================================================\r\n# BOUCLE PRINCIPALE\r\n# =============================================================================\r\nfor pt in points:\r\n    try:\r\n        pt_xyz = pt.ToRevitType()\r\n\r\n        # --- Lancer le rayon ---\r\n        ref_context = ri.FindNearest(pt_xyz, dir_xyz)\r\n        if not ref_context:\r\n            errors.append(\"Aucune intersection pour : {}\".format(pt))\r\n            no_hit_points.append(pt)\r\n            continue\r\n\r\n        raw_ref = ref_context.GetReference()\r\n\r\n        # --- Point d'intersection exact sur la face (repère projet hôte) ---\r\n        proj_pt = raw_ref.GlobalPoint\r\n\r\n        # --- Vérifier que la référence est bien dans le lien ---\r\n        if raw_ref.LinkedElementId == ElementId.InvalidElementId:\r\n            errors.append(\"Référence hors lien pour : {}\".format(pt))\r\n            continue\r\n\r\n        # --- Récupérer l'élément dans le document lié ---\r\n        elem = link_doc.GetElement(raw_ref.LinkedElementId)\r\n        if elem is None:\r\n            errors.append(\"Élément non trouvé dans le lien pour : {}\".format(pt))\r\n            continue\r\n\r\n        if not isinstance(elem, HostObject):\r\n            errors.append(\"L'élément n'est pas un HostObject : {}\".format(elem.Id))\r\n            continue\r\n\r\n        # --- Face inférieure via HostObjectUtils ---\r\n        bottom_refs = HostObjectUtils.GetBottomFaces(elem)\r\n        if not bottom_refs or len(bottom_refs) == 0:\r\n            errors.append(\"Aucune face inférieure sur : {}\".format(elem.Id))\r\n            continue\r\n\r\n        bottom_ref_local = bottom_refs[0]\r\n        face = elem.GetGeometryObjectFromReference(bottom_ref_local)\r\n        if face is None:\r\n            errors.append(\"Face introuvable sur : {}\".format(elem.Id))\r\n            continue\r\n\r\n        # --- Normale transformée dans le repère projet hôte ---\r\n        face_normal = link_transform.OfVector(face.FaceNormal).Normalize()\r\n\r\n        # --- Direction de référence : BasisX projeté dans le plan de la face ---\r\n        # (évite la rotation de 90° causée par un CrossProduct direct)\r\n        ref_direction = project_on_plane(XYZ.BasisX, face_normal)\r\n\r\n        # --- Référence liée (obligatoire pour NewFamilyInstance sur un lien) ---\r\n        linked_ref = bottom_ref_local.CreateLinkReference(linked_instance)\r\n\r\n        # --- Placement de la famille face-hosted au point d'intersection ---\r\n        new_instance = doc.Create.NewFamilyInstance(\r\n            linked_ref,       # Référence de la face dans le lien\r\n            proj_pt,          # Point exact d'intersection du rayon\r\n            ref_direction,    # Direction d'orientation dans le plan de la face\r\n            family_symbol     # Type de famille (face-hosted ou work-plane-based)\r\n        )\r\n\r\n        # --- Niveau de nomenclature ---\r\n        schedule_level_param = new_instance.get_Parameter(\r\n            BuiltInParameter.INSTANCE_SCHEDULE_ONLY_LEVEL_PARAM\r\n        )\r\n        if schedule_level_param is not None and not schedule_level_param.IsReadOnly:\r\n            schedule_level_param.Set(ref_level.Id)\r\n\r\n        placed_instances.append(new_instance)\r\n\r\n    except Exception as e:\r\n        errors.append(\"Erreur sur {} : {}\".format(pt, str(e)))\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\n# =============================================================================\r\n# OUTPUTS\r\n# OUT[0] : Instances placées\r\n# OUT[1] : Liste des erreurs (pour débogage)\r\n# =============================================================================\r\nOUT = [placed_instances, errors]\r\n",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "3791284da22644aaa66372592a41f70c",
      "Inputs": [
