    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\n\r\n# Références aux assemblies nécessaires\r\nclr.AddReference(\"RevitNodes\")\r\nimport Revit\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\nclr.AddReference(\"RevitServices\")\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\nclr.AddReference(\"RevitAPI\")\r\nfrom Autodesk.Revit.DB import *\r\n\r\n# Récupération du document Revit actuel\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# Fonction d'unwrapping et de vérification de type \"liste\"\r\ndef uwlist(item):\r\n    if not isinstance(item, list):\r\n        item = [item]\r\n    return UnwrapElement(item)\r\n\r\n# Préparation des entrées Dynamo\r\npoints = uwlist(IN[0])\r\nphase = doc.Phases[0]\r\n\r\n# Récupération des salles pour chaque point\r\nrooms = []\r\npoints_outside = []\r\nfor p in points:\r\n    xyz = p.ToXyz()\r\n    room = doc.GetSpaceAtPoint(xyz, phase)\r\n    if room is not None:\r\n        rooms.append(room)\r\n    else:\r\n        points_outside.append(p)\r\n\r\n# Retour des résultats vers Dynamo\r\nOUT = (rooms, points_outside)",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "c2b6a8b30e8a4575bba7fc5285e48b8b",
      "Inputs": [
        {
          "Id": "a4523668bd294d3ea8c354d99ce514f9",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "13caf4abd36f4c60b73ecae9ac1dee6c",
          "Name": "OUT",
          "Description": "Résultat du script Python",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Exécute un script Python intégré."
    },
