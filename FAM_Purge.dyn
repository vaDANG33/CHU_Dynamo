    {
      "ConcreteType": "CoreNodeModels.Input.DirectoryObject, CoreNodeModels",
      "NodeType": "ExtensionNode",
      "Id": "da78d1c1732841548c02922f12d92e81",
      "Inputs": [
        {
          "Id": "b3cf8256b0f24c5a9d2e503f27fd7823",
          "Name": "path",
          "Description": "Chemin d'accès au répertoire (type: chaîne)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "1d419af5d7bc47b1ac4b5bb2c95de147",
          "Name": "directory",
          "Description": "Objet de répertoire.",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Crée un objet de répertoire à partir d'un chemin d'accès"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\n\r\n# --- Références Revit ---\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\nclr.AddReference('RevitServices')\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\n# --- Classe FamilyOption pour contrôler le rechargement des familles ---\r\nclass FamilyOption(IFamilyLoadOptions):\r\n\tdef OnFamilyFound(self, familyInUse, overwriteParameterValues):\r\n\t\toverwriteParameterValues = True\r\n\t\treturn True\r\n\r\n\tdef OnSharedFamilyFound(self, sharedFamily, familyInUse, source, overwriteParameterValues):\r\n\t\tsource = FamilySource.Family\r\n\t\toverwriteParameterValues = True\r\n\t\treturn True\r\n\r\nopts = FamilyOption()\r\n\r\n# --- Entrées Dynamo ---\r\n# IN[0] : Liste des documents familles hôtes (host_family_docs)\r\n# IN[1] : Liste des documents familles imbriquées (nested_family_docs)\r\nhost_family_docs = IN[0] or []\r\nnested_family_docs = IN[1] or []\r\n\r\n# --- Résultats ---\r\nresults = []\r\n\r\n# --- Boucle sur chaque famille hôte ---\r\nfor host_doc in host_family_docs:\r\n    try:\r\n        # Récupération des noms des familles déjà présentes dans la famille hôte\r\n        existing_family_names = set(f.Name for f in FilteredElementCollector(host_doc).OfClass(Family))\r\n        loaded_names = []\r\n\r\n        # Transaction Revit\r\n        tx = Transaction(host_doc, \"Chargement des familles imbriquées\")\r\n        tx.Start()\r\n\r\n        for nested_doc in nested_family_docs:\r\n            nested_name = nested_doc.Title  # Nom de la famille imbriquée\r\n\r\n            # Charger uniquement si la famille imbriquée existe dans l'hôte\r\n            if nested_name in existing_family_names:\r\n                try:\r\n                    # Charger la famille imbriquée\r\n                    host_doc.LoadFamily(nested_doc.PathName, opts)\r\n                    loaded_names.append(\"Chargée : {}\".format(nested_name))\r\n                except Exception as e:\r\n                    loaded_names.append(\"Erreur avec {} : {}\".format(nested_name, e))\r\n            else:\r\n                # La famille imbriquée n'est pas présente dans l'hôte\r\n                loaded_names.append(\"Ignorée (non présente dans hôte) : {}\".format(nested_name))\r\n\r\n        tx.Commit()\r\n\r\n        results.append({\r\n            \"Famille_hôte\": host_doc.Title,\r\n            \"Résultat\": loaded_names\r\n        })\r\n\r\n    except Exception as e_host:\r\n        results.append({\r\n            \"Famille_hôte\": host_doc.Title,\r\n            \"Erreur\": str(e_host)\r\n        })\r\n\r\n# --- Fermeture des documents imbriqués ---\r\nfor nested_doc in nested_family_docs:\r\n    try:\r\n        nested_doc.Close(False)  # False = ne pas sauvegarder\r\n    except: \r\n        pass\r\n\r\n# --- Sortie finale ---\r\nOUT = results",
      "Engine": "IronPython2",
      "EngineName": "IronPython2",
      "VariableInputPorts": true,
      "Id": "1b85785342f74efd8eb8059d785e4098",
      "Inputs": [
        {
          "Id": "20568202ebb74f53bc0af2f3fb30f751",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "76abfff884424dd5a9461a2db5964ff7",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "b75dde836bf64d9caa860a977a8a3da9",
          "Name": "OUT",
          "Description": "Résultat du script Python",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Exécute un script Python intégré."
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr, sys\r\n\r\n# Références Revit & Dynamo\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\n# Chargement d’eTransmit pour Revit 2023\r\nsys.path.append(r'C:\\Program Files\\Autodesk\\eTransmit for Revit 2023')\r\nclr.AddReference('eTransmitForRevitDB')\r\nimport eTransmitForRevitDB as eTransmit\r\n\r\n# Application Revit\r\nuiapp = DocumentManager.Instance.CurrentUIApplication\r\napp   = uiapp.Application\r\n\r\n# IN[0] : liste de FamilyDocument déjà ouverts\r\nfamily_docs = IN[0]\r\n\r\n# Purge unused (5 passes) pour chaque document\r\nfor fam_doc in family_docs:\r\n    for _ in range(5):\r\n        eTransmit.eTransmitUpgradeOMatic(app).purgeUnused(fam_doc)\r\n\r\n# On ne sauve ni ne ferme ici, on renvoie juste les documents\r\nOUT = family_docs",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "4798fada674b42d3ab4f81a7d52ce072",
      "Inputs": [
        {
          "Id": "8051f2310cb24f7b936c99e28a58ca1b",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "231f2d4b140846f38852472cfb67800f",
          "Name": "OUT",
          "Description": "Résultat du script Python",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Exécute un script Python intégré."
    },
