          "Name": "",
          "Description": "Sortie du noeud",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Visualiser la sortie du nœud"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import SaveAsOptions\r\n\r\nimport os\r\n\r\n# 📥 Entrée depuis Dynamo\r\ndocs_familles = IN[0]  # Liste de documents de familles déjà ouverts\r\n\r\n# 📤 Liste des résultats\r\nresultats = []\r\n\r\nfor doc in docs_familles:\r\n    try:\r\n        # 📂 Chemin actuel de la famille\r\n        chemin_actuel = doc.PathName\r\n        \r\n        # Si la famille n'est pas encore enregistrée, doc.PathName peut être vide\r\n        if not chemin_actuel:\r\n            resultats.append(f\"⚠️ Impossible de déterminer le chemin pour la famille '{doc.Title}' (non enregistrée).\")\r\n            continue\r\n\r\n        # 📛 Nom du fichier .rfa\r\n        nom_fichier = os.path.basename(chemin_actuel)\r\n        if not nom_fichier.lower().endswith(\".rfa\"):\r\n            nom_fichier += \".rfa\"\r\n\r\n        # 📁 Répertoire d'origine\r\n        dossier_origine = os.path.dirname(chemin_actuel)\r\n\r\n        # 📁 Nouveau chemin de sauvegarde = même dossier + même nom\r\n        chemin_sauvegarde = os.path.join(dossier_origine, nom_fichier)\r\n\r\n        # ⚙️ Options d'enregistrement\r\n        options = SaveAsOptions()\r\n        options.Compact = True\r\n        options.OverwriteExistingFile = True\r\n\r\n        # 💾 Sauvegarde\r\n        doc.SaveAs(chemin_sauvegarde, options)\r\n\r\n        # ❌ Fermeture du document\r\n        doc.Close(False)  # False = ne pas enregistrer à nouveau\r\n\r\n        resultats.append(f\"✅ Sauvegardé et fermé : {chemin_sauvegarde}\")\r\n\r\n    except Exception as e:\r\n        resultats.append(f\"⚠️ Erreur avec '{doc.Title}' : {str(e)}\")\r\n\r\n# 🔄 Sortie vers Dynamo\r\nOUT = resultats",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "4fdd5c4b4f5449849cef179f4f6eacf3",
      "Inputs": [
        {
          "Id": "de39b109b61144708a38711eb9dcfcca",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "3389aa44e1a84a969d70a4450214798a",
          "Name": "OUT",
          "Description": "Résultat du script Python",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Exécute un script Python intégré."
    },
