    {
      "ConcreteType": "Dynamo.Graph.Nodes.ZeroTouch.DSFunction, DynamoCore",
      "NodeType": "FunctionNode",
      "FunctionSignature": "Revit.Elements.Group.ByElements@Revit.Elements.Element[]",
      "Id": "41e97a32713242b19bcb3ce050540d60",
      "Inputs": [
        {
          "Id": "e83c61592e274affa7d862d6ed93835d",
          "Name": "elements",
          "Description": "Éléments Revit à regrouper.\n\nElement[]",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "22766952a9b24f10944cfc0720282ecc",
          "Name": "Group",
          "Description": "Nouveau type de groupe",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Auto",
      "Description": "Crée un type de groupe, avec tous les éléments d'entrée.\n\nGroup.ByElements (elements: Element[]): Group"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\nclr.AddReference(\"RevitNodes\")\r\nimport Revit\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\nclr.AddReference(\"RevitServices\")\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\ncurves = UnwrapElement(IN[0])\r\nareaView = UnwrapElement(IN[1])  # Doit être une ViewPlan de type Area\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\no = areaView.Origin\r\nn = areaView.ViewDirection\r\nif o and n: \r\n    sketchplane = SketchPlane.Create(doc, Plane.CreateByNormalAndOrigin(n, o))\r\n    doccreation = doc.Create\r\n    elementlist = list()\r\n    for curve in curves:\r\n        # NewAreaBoundaryLine crée une ligne à la fois (pas de CurveArray)\r\n        areaBoundary = doccreation.NewAreaBoundaryLine(sketchplane, curve.ToRevitType(), areaView)\r\n        elementlist.append(areaBoundary)\r\nelse: \r\n    elementlist = []\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nif isinstance(IN[0], list): OUT = elementlist\r\nelse: OUT = elementlist[0] if elementlist else None\r\n",
      "Engine": "IronPython2",
      "EngineName": "IronPython2",
      "VariableInputPorts": true,
      "Id": "095006edf92b4dc6b6418a7fa9b36a29",
      "Inputs": [
        {
          "Id": "1943f448828945a09067df1defe2b0b3",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "f7718d31133b47e18593db912bfda1c1",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "41fd96af6a3c4f86b53ff307fb23b5e9",
          "Name": "OUT",
          "Description": "Résultat du script Python",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Exécute un script Python intégré."
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.ZeroTouch.DSFunction, DynamoCore",
      "NodeType": "FunctionNode",
